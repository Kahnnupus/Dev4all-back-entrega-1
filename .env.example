NODE_ENV=development
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<senha>@<cluster>.mongodb.net/dev4all?appName=dev4all

# JWT (use uma string longa e aleatória - mínimo 64 caracteres)
JWT_SECRET=sua_chave_secreta_jwt_aqui_minimo_64_caracteres_muito_segura
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:3000
